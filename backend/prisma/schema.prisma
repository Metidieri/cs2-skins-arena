generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  balance   Float    @default(1000.0)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory        UserSkin[]
  betsA            Battle[]       @relation("playerA")
  betsB            Battle[]       @relation("playerB")
  transactions     Transaction[]
  jackpots         Jackpot[]
  jackpotEntries   JackpotEntry[]
  listingsAsSeller Listing[]      @relation("Seller")
  listingsAsBuyer  Listing[]      @relation("Buyer")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Skin {
  id        Int      @id @default(autoincrement())
  name      String
  weapon    String
  rarity    String
  price     Float
  imageUrl  String
  createdAt DateTime @default(now())

  owners         UserSkin[]
  jackpotEntries JackpotEntry[]
  listings       Listing[]
}

model UserSkin {
  id     Int  @id @default(autoincrement())
  userId Int
  skinId Int
  user   User @relation(fields: [userId], references: [id])
  skin   Skin @relation(fields: [skinId], references: [id])

  @@unique([userId, skinId])
}

model Battle {
  id          Int      @id @default(autoincrement())
  playerAId   Int
  playerBId   Int?
  winnerId    Int?
  skinAId     Int
  skinBId     Int?
  status      String   @default("waiting")
  seed        String
  result      String?
  betType     String   @default("skin")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  playerA User @relation("playerA", fields: [playerAId], references: [id])
  playerB User? @relation("playerB", fields: [playerBId], references: [id])
}

model Jackpot {
  id         String    @id @default(uuid())
  status     String    @default("open")
  seed       String    @default("")
  winnerId   Int?
  totalValue Float     @default(0)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  entries JackpotEntry[]
  winner  User?          @relation(fields: [winnerId], references: [id])
}

model JackpotEntry {
  id        String   @id @default(uuid())
  jackpotId String
  userId    Int
  skinId    Int
  value     Float
  createdAt DateTime @default(now())

  jackpot Jackpot @relation(fields: [jackpotId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  skin    Skin    @relation(fields: [skinId], references: [id])

  @@index([jackpotId])
}

model Listing {
  id        String    @id @default(uuid())
  sellerId  Int
  skinId    Int
  price     Float
  status    String    @default("active")
  createdAt DateTime  @default(now())
  soldAt    DateTime?
  buyerId   Int?

  seller User  @relation("Seller", fields: [sellerId], references: [id])
  buyer  User? @relation("Buyer", fields: [buyerId], references: [id])
  skin   Skin  @relation(fields: [skinId], references: [id])

  @@index([status, createdAt])
  @@index([sellerId])
}
