# Conexión a la base de datos (Prisma).
# Local: file:./dev.db (SQLite). En Railway puedes usar PostgreSQL: postgresql://USER:PASS@HOST:PORT/DB
DATABASE_URL=

# Secreto para firmar JWT de acceso. Usa un valor largo y aleatorio en producción.
JWT_SECRET=

# Secreto separado para refresh tokens (reservado para uso futuro).
JWT_REFRESH_SECRET=

# Puerto en el que escucha el servidor.
PORT=3000

# Entorno: development | production | test
NODE_ENV=production

# URL pública del frontend (para CORS y redirecciones de socket.io).
# Ej: https://cs2-skins-arena.vercel.app
FRONTEND_URL=
